# ============================================================
# DFX_ate environment configuration  (SINGLE SOURCE OF TRUTH)
# ------------------------------------------------------------
# Copy this file to ".env" placed NEXT TO DFX_Tester.exe
# (or at the repo root during development). Do NOT commit .env.
# Every key is optional; missing keys fall back to safe defaults.
# ============================================================

# --- Secrets ---
LOG_ENCRYPTION_PASSWORD=change-me-on-the-floor
ADMIN_REPORT_PASSWORD=change-me-on-the-floor

# --- Default admin seed (applied only on first database creation) ---
DEFAULT_ADMIN_USERNAME=lior
DEFAULT_ADMIN_PASSWORD=123
DEFAULT_ADMIN_EMPLOYEE_ID=0000

# --- Application identity ---
APP_VERSION=0.1.0-Beta
TESTER_SERIAL_NUMBER=ATE-DFX-001
LOAD_SERIALS=PRODIGIT-CH1,PRODIGIT-CH2,PRODIGIT-CH3,PRODIGIT-CH4
INPUT_CONNECTED_TARGET_V=24
INPUT_CONNECTED_TOLERANCE_PCT=5
LOAD_RESISTANCE_50W_OHM=12.5
LOAD_RESISTANCE_300W_OHM=2.2

# --- Hardware backend ---
HARDWARE_BACKEND=mock
PRODIGIT_VISA_RESOURCE=
PRODIGIT_VISA_BACKEND=
PRODIGIT_VISA_TIMEOUT_MS=5000
PRODIGIT_QUERY_ID=*IDN?
PRODIGIT_QUERY_INPUT_VOLT=MEAS:VOLT?
PRODIGIT_QUERY_POLARITY=MEAS:POL?
PRODIGIT_QUERY_VOLTAGE=MEAS:VOLT?
PRODIGIT_QUERY_CURRENT=MEAS:CURR?
PRODIGIT_QUERY_POWER=MEAS:POW?
PRODIGIT_SET_RESISTANCE=RES {value}
PRODIGIT_SET_VOLTAGE=
PRODIGIT_SET_RELAY=
PRODIGIT_SELECT_SLOT=

# --- Feature flags (true/false) ---
SHOW_LIVE_MONITOR=true
SHOW_SEARCH_BAR=false

# --- Pre-test UUT options (comma-separated) ---
UUT_TYPES=Power main,Power Ctrl DSP,Demo UUT
